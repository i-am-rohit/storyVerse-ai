# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO

# Database (defaults to SQLite)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=storyverse_ai
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# Production security
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_HSTS_SECONDS=31536000

# ---------------------------------------------------------------------------
# Meta Llama 3.1 / 3.2 — story writing & summarization (recommended)
# ---------------------------------------------------------------------------
# Option A — Local Ollama (free, private):
#   brew install ollama   OR   download from https://ollama.com
#   ollama serve
#   ollama pull llama3.1
#   LLM_ENABLED=true
#   LLM_PROVIDER=ollama
#   LLAMA_MODEL=llama3.1
#
# Option B — Groq free API (cloud, fast):
#   https://console.groq.com → create API key
#   LLM_ENABLED=true
#   LLM_PROVIDER=groq
#   GROQ_API_KEY=gsk_your-groq-key
#   LLAMA_MODEL=llama-3.1-8b-instant

LLM_ENABLED=true
LLM_PROVIDER=ollama
LLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
# GROQ_API_KEY=gsk-your-groq-key

# ---------------------------------------------------------------------------
# Legacy LLM providers (optional)
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---------------------------------------------------------------------------
# ElevenLabs — text-to-speech for audiobook narration
# ---------------------------------------------------------------------------
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL=eleven_multilingual_v2

# Optional: override default models
# LLAMA_MODEL=llama3.2
# LLAMA_MODEL=llama-3.1-70b-versatile

# ---------------------------------------------------------------------------
# Social login (optional — buttons show on login/register when configured)
# ---------------------------------------------------------------------------
# Google / Gmail — https://console.cloud.google.com/apis/credentials
# Redirect URI: http://127.0.0.1:8000/oauth/google/login/callback/
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# Microsoft / Outlook — https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Redirect URI: http://127.0.0.1:8000/oauth/microsoft/login/callback/
# MICROSOFT_OAUTH_CLIENT_ID=
# MICROSOFT_OAUTH_CLIENT_SECRET=

# Facebook — https://developers.facebook.com/apps/
# Redirect URI: http://127.0.0.1:8000/oauth/facebook/login/callback/
# FACEBOOK_OAUTH_CLIENT_ID=
# FACEBOOK_OAUTH_CLIENT_SECRET=
